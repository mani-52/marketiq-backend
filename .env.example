# ── Tavily (required for real news data) ─────────────────────────────────────
# Get a free key at https://tavily.com (1000 searches/month free)
TAVILY_API_KEY=tvly-your-key-here

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRE_MINUTES=43200

# ── Google OAuth (optional — for Google Sign-In) ──────────────────────────────
# Get credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP (for notification engine) ────────────────────────────────────
# Gmail example: use an App Password (not your main password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=MarketIQ <your@gmail.com>

# ── General ───────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=*

# ── Gemini AI (for analyst-quality insights) ──────────────────────────────────
# Get free key at https://aistudio.google.com/
GEMINI_API_KEY=
